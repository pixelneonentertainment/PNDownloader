<Window x:Class="PixelNeonDownloader.BulutEntegrasyonPenceresi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulut Entegrasyonu"
        Height="580" Width="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="#0A0F1E"
            BorderBrush="#2200FFE5"
            BorderThickness="1"
            CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect Color="#00FFE5" BlurRadius="20"
                              ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- BAŞLIK -->
            <Border Grid.Row="0"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Baslik_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="☁ " Foreground="#00FFE5"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="BULUT ENTEGRASYONU"
                                   Foreground="#00FFE5"
                                   FontFamily="Consolas"
                                   FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="32" Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FF2244"
                            FontFamily="Consolas"
                            Cursor="Hand"
                            Click="Kapat_Click"/>
                </Grid>
            </Border>

            <!-- İÇERİK -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,12">

                    <!-- GOOGLE DRIVE -->
                    <TextBlock Text="GOOGLE DRIVE"
                               Foreground="#7A9CC0"
                               FontFamily="Consolas"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <Border Background="#0D1428"
                            BorderBrush="#1500FFE5"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,12"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔵 " FontSize="20"
                                               VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Google Drive"
                                                   Foreground="#E0F0FF"
                                                   FontFamily="Consolas"
                                                   FontSize="12" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtGDriveDurum"
                                                   Text="Bağlı değil"
                                                   Foreground="#FF2244"
                                                   FontFamily="Consolas"
                                                   FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border x:Name="ToggleGDrive"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Width="48" Height="26"
                                        CornerRadius="13" Cursor="Hand"
                                        MouseLeftButtonDown="ToggleGDrive_Click">
                                    <Ellipse x:Name="ToggleGDriveDaire"
                                             Width="20" Height="20"
                                             Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                            <TextBlock Text="API ANAHTARI"
                                       Foreground="#3A5070"
                                       FontFamily="Consolas"
                                       FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="TxtGDriveApiKey"
                                             Grid.Column="0" Height="32"
                                             Background="#050810" Foreground="#E0F0FF"
                                             BorderBrush="#223A5070" BorderThickness="1"
                                             FontFamily="Consolas" FontSize="11"
                                             Padding="8,6"/>
                                <Button Grid.Column="1" Content="KAYDET"
                                        Height="32" Margin="6,0,0,0"
                                        Background="Transparent"
                                        BorderBrush="#2200FFE5" BorderThickness="1"
                                        Foreground="#00FFE5"
                                        FontFamily="Consolas" FontSize="9"
                                        FontWeight="Bold" Cursor="Hand"
                                        Click="BtnGDriveKaydet_Click"/>
                            </Grid>

                            <TextBlock Text="YÜKLEME KLASÖRÜ"
                                       Foreground="#3A5070"
                                       FontFamily="Consolas"
                                       FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtGDriveKlasor"
                                     Height="32" Margin="0,0,0,10"
                                     Background="#050810" Foreground="#E0F0FF"
                                     BorderBrush="#223A5070" BorderThickness="1"
                                     FontFamily="Consolas" FontSize="11"
                                     Padding="8,6" CaretBrush="#00FFE5"
                                     Text="PixelNeon Downloads"/>

                            <!-- Otomatik Yükleme -->
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="OTOMATİK YÜKLEME"
                                               Foreground="#E0F0FF"
                                               FontFamily="Consolas"
                                               FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="İndirme tamamlanınca Drive'a yükle"
                                               Foreground="#7A9CC0"
                                               FontFamily="Consolas"
                                               FontSize="9" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border x:Name="ToggleGDriveOto"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Width="48" Height="26"
                                        CornerRadius="13" Cursor="Hand"
                                        MouseLeftButtonDown="ToggleGDriveOto_Click">
                                    <Ellipse x:Name="ToggleGDriveOtoDaire"
                                             Width="20" Height="20"
                                             Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                            <Button Content="📤 SEÇILI DOSYAYI DRIVE'A YÜKLE"
                                    Height="34" Margin="0,10,0,0"
                                    Background="Transparent"
                                    BorderBrush="#2200FFE5" BorderThickness="1"
                                    Foreground="#00FFE5"
                                    FontFamily="Consolas" FontSize="10"
                                    FontWeight="Bold" Cursor="Hand"
                                    Click="BtnGDriveYukle_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- ONEDRIVE -->
                    <TextBlock Text="ONEDRIVE"
                               Foreground="#7A9CC0"
                               FontFamily="Consolas"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <Border Background="#0D1428"
                            BorderBrush="#1500FFE5"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,12"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔷 " FontSize="20"
                                               VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Microsoft OneDrive"
                                                   Foreground="#E0F0FF"
                                                   FontFamily="Consolas"
                                                   FontSize="12" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtOneDriveDurum"
                                                   Text="Bağlı değil"
                                                   Foreground="#FF2244"
                                                   FontFamily="Consolas"
                                                   FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border x:Name="ToggleOneDrive"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Width="48" Height="26"
                                        CornerRadius="13" Cursor="Hand"
                                        MouseLeftButtonDown="ToggleOneDrive_Click">
                                    <Ellipse x:Name="ToggleOneDriveDaire"
                                             Width="20" Height="20"
                                             Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                            <TextBlock Text="CLIENT ID"
                                       Foreground="#3A5070"
                                       FontFamily="Consolas"
                                       FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="TxtOneDriveClientId"
                                             Grid.Column="0" Height="32"
                                             Background="#050810" Foreground="#E0F0FF"
                                             BorderBrush="#223A5070" BorderThickness="1"
                                             FontFamily="Consolas" FontSize="11"
                                             Padding="8,6"/>
                                <Button Grid.Column="1" Content="KAYDET"
                                        Height="32" Margin="6,0,0,0"
                                        Background="Transparent"
                                        BorderBrush="#2200FFE5" BorderThickness="1"
                                        Foreground="#00FFE5"
                                        FontFamily="Consolas" FontSize="9"
                                        FontWeight="Bold" Cursor="Hand"
                                        Click="BtnOneDriveKaydet_Click"/>
                            </Grid>

                            <TextBlock Text="YÜKLEME KLASÖRÜ"
                                       Foreground="#3A5070"
                                       FontFamily="Consolas"
                                       FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtOneDriveKlasor"
                                     Height="32" Margin="0,0,0,10"
                                     Background="#050810" Foreground="#E0F0FF"
                                     BorderBrush="#223A5070" BorderThickness="1"
                                     FontFamily="Consolas" FontSize="11"
                                     Padding="8,6" CaretBrush="#00FFE5"
                                     Text="PixelNeon Downloads"/>

                            <!-- Otomatik Yükleme -->
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="OTOMATİK YÜKLEME"
                                               Foreground="#E0F0FF"
                                               FontFamily="Consolas"
                                               FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="İndirme tamamlanınca OneDrive'a yükle"
                                               Foreground="#7A9CC0"
                                               FontFamily="Consolas"
                                               FontSize="9" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border x:Name="ToggleOneDriveOto"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Width="48" Height="26"
                                        CornerRadius="13" Cursor="Hand"
                                        MouseLeftButtonDown="ToggleOneDriveOto_Click">
                                    <Ellipse x:Name="ToggleOneDriveOtoDaire"
                                             Width="20" Height="20"
                                             Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                            <Button Content="📤 SEÇILI DOSYAYI ONEDRIVE'A YÜKLE"
                                    Height="34" Margin="0,10,0,0"
                                    Background="Transparent"
                                    BorderBrush="#2244FF" BorderThickness="1"
                                    Foreground="#4488FF"
                                    FontFamily="Consolas" FontSize="10"
                                    FontWeight="Bold" Cursor="Hand"
                                    Click="BtnOneDriveYukle_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- YÜKLEME GEÇMİŞİ -->
                    <TextBlock Text="YÜKLEME GEÇMİŞİ"
                               Foreground="#7A9CC0"
                               FontFamily="Consolas"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <Border Background="#0D1428"
                            BorderBrush="#1500FFE5"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,12">
                        <StackPanel x:Name="YuklemeGecmisiPaneli">
                            <TextBlock Text="Henüz yükleme yapılmadı"
                                       Foreground="#3A5070"
                                       FontFamily="Consolas"
                                       FontSize="10"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ALT -->
            <Border Grid.Row="2"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <TextBlock x:Name="TxtDurum"
                               Text="Hazır"
                               Foreground="#3A5070"
                               FontFamily="Consolas" FontSize="10"
                               VerticalAlignment="Center"/>
                    <Button Content="KAPAT"
                            HorizontalAlignment="Right"
                            Width="100" Height="34"
                            Background="Transparent"
                            BorderBrush="#2200FFE5" BorderThickness="1"
                            Foreground="#00FFE5"
                            FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                            Cursor="Hand" Click="Kapat_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
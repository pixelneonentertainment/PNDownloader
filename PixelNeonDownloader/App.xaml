<Application x:Class="PixelNeonDownloader.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- Theme brushes (defaults match Cyan theme) -->
        <SolidColorBrush x:Key="AnaRenk" Color="#00FFE5" />
        <SolidColorBrush x:Key="IkinciRenk" Color="#BD00FF" />
        <SolidColorBrush x:Key="VurguRenk" Color="#39FF14" />
        <SolidColorBrush x:Key="HataRenk" Color="#FF2244" />
        <SolidColorBrush x:Key="ArkaplanRenk" Color="#050810" />
        <SolidColorBrush x:Key="PanelRenk" Color="#0A0F1E" />
        <SolidColorBrush x:Key="EkRenk1" Color="#00B5A8" />
        <SolidColorBrush x:Key="EkRenk2" Color="#0077CC" />
        <SolidColorBrush x:Key="EkRenk3" Color="#FFAA00" />
        <SolidColorBrush x:Key="EkRenk4" Color="#CC0077" />

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ArkaplanRenk}"/>
            <Setter Property="Foreground" Value="{DynamicResource AnaRenk}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelRenk}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource PanelRenk}"/>
            <Setter Property="Foreground" Value="{DynamicResource AnaRenk}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AnaRenk}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ArkaplanRenk}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IkinciRenk}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ArkaplanRenk}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
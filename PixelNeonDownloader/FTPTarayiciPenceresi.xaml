<Window x:Class="PixelNeonDownloader.FTPTarayiciPenceresi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FTP Tarayıcı"
        Height="620" Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="#0A0F1E"
            BorderBrush="#2200FFE5"
            BorderThickness="1"
            CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect Color="#00FFE5" BlurRadius="20"
                              ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- BAŞLIK -->
            <Border Grid.Row="0"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Baslik_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🌐 " Foreground="#00FFE5"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="FTP TARAYICI"
                                   Foreground="#00FFE5"
                                   FontFamily="Consolas"
                                   FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="32" Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FF2244"
                            FontFamily="Consolas"
                            Cursor="Hand"
                            Click="Kapat_Click"/>
                </Grid>
            </Border>

            <!-- BAĞLANTI PANELİ -->
            <Border Grid.Row="1"
                    Background="#0D1428"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,0,0,1"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="TxtSunucu"
                             Height="32" Margin="0,0,6,0"
                             Background="#050810" Foreground="#E0F0FF"
                             BorderBrush="#223A5070" BorderThickness="1"
                             FontFamily="Consolas" FontSize="11"
                             Padding="8,6" CaretBrush="#00FFE5"
                             Text="ftp://"/>

                    <TextBox Grid.Column="1"
                             x:Name="TxtKullanici"
                             Height="32" Margin="0,0,6,0"
                             Background="#050810" Foreground="#E0F0FF"
                             BorderBrush="#223A5070" BorderThickness="1"
                             FontFamily="Consolas" FontSize="11"
                             Padding="8,6" CaretBrush="#00FFE5"
                             Text="anonymous"/>

                    <PasswordBox Grid.Column="2"
                                 x:Name="TxtSifre"
                                 Height="32" Margin="0,0,6,0"
                                 Background="#050810" Foreground="#E0F0FF"
                                 BorderBrush="#223A5070" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="11"
                                 Padding="8,6"/>

                    <TextBox Grid.Column="3"
                             x:Name="TxtPort"
                             Height="32" Margin="0,0,6,0"
                             Background="#050810" Foreground="#E0F0FF"
                             BorderBrush="#223A5070" BorderThickness="1"
                             FontFamily="Consolas" FontSize="11"
                             Padding="8,6" CaretBrush="#00FFE5"
                             Text="21"/>

                    <Button Grid.Column="4"
                            Content="BAĞLAN"
                            Height="32"
                            Background="Transparent"
                            BorderBrush="#3900FFE5" BorderThickness="1"
                            Foreground="#00FFE5"
                            FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                            Cursor="Hand"
                            Click="BtnBaglan_Click"/>
                </Grid>
            </Border>

            <!-- YOL ÇUBUĞU -->
            <Border Grid.Row="2"
                    Background="#050810"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,0,0,1"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="⬆ ÜST"
                            Height="26" Padding="8,0" Margin="0,0,6,0"
                            Background="Transparent"
                            BorderBrush="#2200FFE5" BorderThickness="1"
                            Foreground="#00FFE5"
                            FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                            Cursor="Hand"
                            Click="BtnUstKlasor_Click"/>

                    <Button Grid.Column="1"
                            Content="🔄 YENİLE"
                            Height="26" Padding="8,0" Margin="0,0,6,0"
                            Background="Transparent"
                            BorderBrush="#2200FFE5" BorderThickness="1"
                            Foreground="#00FFE5"
                            FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                            Cursor="Hand"
                            Click="BtnYenile_Click"/>

                    <Border Grid.Column="2"
                            Background="#0D1428"
                            BorderBrush="#1500FFE5"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,4">
                        <TextBlock x:Name="TxtMevcutYol"
                                   Text="/"
                                   Foreground="#00FFE5"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Column="3"
                               x:Name="TxtBaglanti"
                               Text="● Bağlı değil"
                               Foreground="#FF2244"
                               FontFamily="Consolas"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- DOSYA LİSTESİ -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Başlık -->
                <Border Grid.Row="0"
                        Background="#0A0F1E"
                        BorderBrush="#1500FFE5"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TÜR"
                                   Foreground="#3A5070" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="AD"
                                   Foreground="#3A5070" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="8,0"/>
                        <TextBlock Grid.Column="2" Text="BOYUT"
                                   Foreground="#3A5070" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="TARİH"
                                   Foreground="#3A5070" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ListBox x:Name="DosyaListesi"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="DosyaListesi_DoubleClick">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#0D0A0F1E"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0F162040"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2200FFE5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ContextMenu>
                        <ContextMenu Background="#0D1428"
                                     BorderBrush="#2200FFE5" BorderThickness="1">
                            <MenuItem Header="⬇  İndir"
                                      Foreground="#00FFE5"
                                      FontFamily="Consolas" FontSize="11"
                                      Background="Transparent"
                                      Click="MenuIndir_Click"/>
                            <MenuItem Header="📁  Klasöre Gir"
                                      Foreground="#00FFE5"
                                      FontFamily="Consolas" FontSize="11"
                                      Background="Transparent"
                                      Click="MenuKlasoreGir_Click"/>
                            <Separator Background="#1500FFE5"/>
                            <MenuItem Header="📋  URL Kopyala"
                                      Foreground="#00FFE5"
                                      FontFamily="Consolas" FontSize="11"
                                      Background="Transparent"
                                      Click="MenuUrlKopyala_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                <!-- Yükleniyor overlay -->
                <Border x:Name="YukleniyorOverlay"
                        Grid.Row="0" Grid.RowSpan="2"
                        Background="#AA050810"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="⟳"
                                   Foreground="#00FFE5"
                                   FontSize="32"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Yükleniyor..."
                                   Foreground="#00FFE5"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ALT -->
            <Border Grid.Row="4"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <TextBlock x:Name="TxtDurum"
                               Text="FTP sunucusuna bağlanın"
                               Foreground="#3A5070"
                               FontFamily="Consolas" FontSize="10"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnIndir"
                                Content="⬇ İNDİR"
                                Height="34" Padding="14,0" Margin="0,0,8,0"
                                Background="Transparent"
                                BorderBrush="#3939FF14" BorderThickness="1"
                                Foreground="#39FF14"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Cursor="Hand" IsEnabled="False"
                                Click="BtnIndir_Click"/>
                        <Button Content="KAPAT"
                                Width="90" Height="34"
                                Background="Transparent"
                                BorderBrush="#2200FFE5" BorderThickness="1"
                                Foreground="#00FFE5"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Cursor="Hand"
                                Click="Kapat_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
<Window x:Class="PixelNeonDownloader.KurtarmaPenceresi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yarıda Kalan İndirmeler"
        Height="420" Width="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    

    <Border Background="#0A0F1E"
            BorderBrush="#22FFD700"
            BorderThickness="1"
            CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect Color="#FFD700" BlurRadius="20"
                              ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- BAŞLIK -->
            <Border Grid.Row="0"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Baslik_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚠ " Foreground="#FFD700"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="YARIDA KALAN İNDİRMELER"
                                   Foreground="#FFD700"
                                   FontFamily="Consolas"
                                   FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="32" Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FF2244"
                            FontFamily="Consolas"
                            Cursor="Hand"
                            Click="Kapat_Click"/>
                </Grid>
            </Border>

            <!-- İÇERİK -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Bilgi Mesajı -->
                <Border Grid.Row="0"
                        Background="#0D1428"
                        BorderBrush="#22FFD700"
                        BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <TextBlock Text="Uygulama kapanmadan önce tamamlanamayan indirmeler bulundu. Kaldığı yerden devam etmek istiyor musunuz?"
                               Foreground="#7A9CC0"
                               FontFamily="Consolas"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Liste -->
                <ListView x:Name="LogListesi"
                          Grid.Row="1"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="#E0F0FF">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="60" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          x:Name="ChkSecili"
                                          IsChecked="True"
                                          VerticalAlignment="Center"
                                          Margin="12,0,12,0"/>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DosyaAdi}"
                                               Foreground="#E0F0FF"
                                               FontFamily="Consolas"
                                               FontSize="12" FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,4,0,0">
                                        <TextBlock Text="{Binding KurtarilabilirMetin}"
                                                   Foreground="#39FF14"
                                                   FontFamily="Consolas"
                                                   FontSize="10"/>
                                        <TextBlock Text=" / "
                                                   Foreground="#3A5070"
                                                   FontFamily="Consolas"
                                                   FontSize="10"/>
                                        <TextBlock Text="{Binding ToplamMetin}"
                                                   Foreground="#7A9CC0"
                                                   FontFamily="Consolas"
                                                   FontSize="10"/>
                                        <TextBlock Text=" — "
                                                   Foreground="#3A5070"
                                                   FontFamily="Consolas"
                                                   FontSize="10"/>
                                        <TextBlock Text="{Binding TarihMetni}"
                                                   Foreground="#3A5070"
                                                   FontFamily="Consolas"
                                                   FontSize="10"/>
                                    </StackPanel>
                                    <ProgressBar Value="{Binding IlerlemeYuzde}"
                                                 Maximum="100" Height="3"
                                                 Margin="0,4,16,0"
                                                 Background="#0D1428"
                                                 BorderThickness="0">
                                        <ProgressBar.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF00FFE5" Offset="0"/>
                                                <GradientStop Color="#FFBD00FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </ProgressBar.Foreground>
                                    </ProgressBar>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="🗑"
                                        Width="32" Height="32"
                                        Margin="0,0,12,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="14"
                                        Cursor="Hand"
                                        Tag="{Binding Id}"
                                        Click="BtnLogSil_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#110D1428"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- ALT BUTONLAR -->
            <Border Grid.Row="2"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <Button Content="🗑 TÜMÜNÜ SİL"
                            Height="32" Padding="12,0"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            BorderBrush="#22FF006E" BorderThickness="1"
                            Foreground="#FF006E"
                            FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                            Cursor="Hand"
                            Click="BtnTumunuSil_Click"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="ATLA"
                                Width="80" Height="32"
                                Margin="0,0,8,0"
                                Background="Transparent"
                                BorderBrush="#223A5070" BorderThickness="1"
                                Foreground="#7A9CC0"
                                FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                Cursor="Hand"
                                Click="Kapat_Click"/>
                        <Button Content="▶ DEVAM ET"
                                Width="120" Height="32"
                                Background="Transparent"
                                BorderBrush="#3939FF14" BorderThickness="1"
                                Foreground="#39FF14"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Cursor="Hand"
                                Click="BtnDevamEt_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
<Window x:Class="PixelNeonDownloader.AIAsistanPenceresi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI İndirme Asistanı"
        Height="620" Width="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="#0A0F1E"
            BorderBrush="#22BD00FF"
            BorderThickness="1"
            CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect Color="#BD00FF" BlurRadius="20"
                              ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- BAŞLIK -->
            <Border Grid.Row="0"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Baslik_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🤖 " Foreground="#BD00FF"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="AI İNDİRME ASİSTANI"
                                   Foreground="#BD00FF"
                                   FontFamily="Consolas"
                                   FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Border Background="#0D1428"
                                BorderBrush="#22BD00FF"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="6,2"
                                Margin="10,0,0,0">
                            <TextBlock Text="Claude AI"
                                       Foreground="#7A9CC0"
                                       FontFamily="Consolas"
                                       FontSize="9"/>
                        </Border>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="32" Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FF2244"
                            FontFamily="Consolas"
                            Cursor="Hand"
                            Click="Kapat_Click"/>
                </Grid>
            </Border>

            <!-- İÇERİK -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,12">

                    <!-- API Key -->
                    <Border x:Name="PanelAPIKey"
                            Background="#0D1428"
                            BorderBrush="#22FFD700"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,12"
                            Margin="0,0,0,14"
                            Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="🔑 ANTHROPIC API ANAHTARI"
                                       Foreground="#FFD700"
                                       FontFamily="Consolas"
                                       FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="API anahtarınızı girin. Ücretsiz almak için: console.anthropic.com"
                                       Foreground="#7A9CC0"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="TxtAPIKey"
                                             Grid.Column="0"
                                             Height="34"
                                             Background="#050810"
                                             Foreground="#E0F0FF"
                                             BorderBrush="#223A5070"
                                             BorderThickness="1"
                                             FontFamily="Consolas"
                                             FontSize="11"
                                             Padding="8,6"/>
                                <Button Grid.Column="1"
                                        Content="KAYDET"
                                        Height="34" Margin="6,0,0,0"
                                        Background="Transparent"
                                        BorderBrush="#22FFD700" BorderThickness="1"
                                        Foreground="#FFD700"
                                        FontFamily="Consolas" FontSize="10"
                                        FontWeight="Bold" Cursor="Hand"
                                        Click="BtnAPIKeyKaydet_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- URL Analizi -->
                    <TextBlock Text="🔍 URL ANALİZİ"
                               Foreground="#7A9CC0"
                               FontFamily="Consolas"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <Border Background="#0D1428"
                            BorderBrush="#1500FFE5"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,12"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="URL yapıştır — AI otomatik analiz eder"
                                       Foreground="#3A5070"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtAnalizURL"
                                         Grid.Column="0"
                                         Height="36"
                                         Background="#050810" Foreground="#E0F0FF"
                                         BorderBrush="#223A5070" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="11"
                                         Padding="8,8" CaretBrush="#BD00FF"/>
                                <Button Grid.Column="1"
                                        Content="ANALİZ"
                                        Height="36" Margin="6,0,0,0"
                                        Background="Transparent"
                                        BorderBrush="#22BD00FF" BorderThickness="1"
                                        Foreground="#BD00FF"
                                        FontFamily="Consolas" FontSize="10"
                                        FontWeight="Bold" Cursor="Hand"
                                        Click="BtnAnalizEt_Click"/>
                            </Grid>

                            <!-- Yükleniyor -->
                            <TextBlock x:Name="TxtAnalizYukleniyor"
                                       Text="🤖 AI analiz ediyor..."
                                       Foreground="#BD00FF"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,8"/>

                            <!-- Analiz Sonucu -->
                            <Border x:Name="AnalizSonucPaneli"
                                    Background="#060C1A"
                                    BorderBrush="#1500FFE5"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="12,10"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="DOSYA TÜRÜ"
                                                   Foreground="#3A5070"
                                                   FontFamily="Consolas"
                                                   FontSize="9"/>
                                        <TextBlock x:Name="TxtSonucTur"
                                                   Foreground="#BD00FF"
                                                   FontFamily="Consolas"
                                                   FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="ÖNERİLEN KLASÖR"
                                                   Foreground="#3A5070"
                                                   FontFamily="Consolas"
                                                   FontSize="9"/>
                                        <TextBlock x:Name="TxtSonucKlasor"
                                                   Foreground="#00FFE5"
                                                   FontFamily="Consolas"
                                                   FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="PARÇA SAYISI"
                                                   Foreground="#3A5070"
                                                   FontFamily="Consolas"
                                                   FontSize="9"/>
                                        <TextBlock x:Name="TxtSonucParca"
                                                   Foreground="#39FF14"
                                                   FontFamily="Consolas"
                                                   FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="RİSK SEVİYESİ"
                                                   Foreground="#3A5070"
                                                   FontFamily="Consolas"
                                                   FontSize="9"/>
                                        <TextBlock x:Name="TxtSonucRisk"
                                                   FontFamily="Consolas"
                                                   FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="OTOMATİK ÇIKART"
                                                   Foreground="#3A5070"
                                                   FontFamily="Consolas"
                                                   FontSize="9"/>
                                        <TextBlock x:Name="TxtSonucCikart"
                                                   FontFamily="Consolas"
                                                   FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- AI Önerisi -->
                                    <Border Background="#0A0F1E"
                                            BorderBrush="#22BD00FF"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="8,6"
                                            Margin="0,6,0,8">
                                        <TextBlock x:Name="TxtSonucOneri"
                                                   Foreground="#BD00FF"
                                                   FontFamily="Consolas"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"/>
                                    </Border>

                                    <Button Content="⬇ BU AYARLARLA İNDİR"
                                            Height="32"
                                            Background="Transparent"
                                            BorderBrush="#3900FFE5" BorderThickness="1"
                                            Foreground="#00FFE5"
                                            FontFamily="Consolas" FontSize="10"
                                            FontWeight="Bold" Cursor="Hand"
                                            Click="BtnAIileIndir_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Akıllı Temizlik -->
                    <TextBlock Text="🧹 AKILLI TEMİZLİK ÖNERİLERİ"
                               Foreground="#7A9CC0"
                               FontFamily="Consolas"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <Border Background="#0D1428"
                            BorderBrush="#1500FFE5"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,12"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="AI, indirilen dosyaları analiz ederek gereksiz dosyaları tespit eder"
                                       Foreground="#3A5070"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <Button x:Name="BtnTemizlikAnaliz"
                                    Content="🔍  DOSYALARI ANALİZ ET"
                                    Height="34"
                                    Background="Transparent"
                                    BorderBrush="#22BD00FF" BorderThickness="1"
                                    Foreground="#BD00FF"
                                    FontFamily="Consolas" FontSize="10"
                                    FontWeight="Bold" Cursor="Hand"
                                    Click="BtnTemizlikAnaliz_Click"
                                    Margin="0,0,0,10"/>

                            <TextBlock x:Name="TxtTemizlikYukleniyor"
                                       Text="🤖 AI analiz ediyor..."
                                       Foreground="#BD00FF"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,8"/>

                            <!-- Temizlik Önerileri Listesi -->
                            <StackPanel x:Name="TemizlikListesi"/>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ALT -->
            <Border Grid.Row="2"
                    BorderBrush="#1500FFE5"
                    BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <TextBlock x:Name="TxtDurum"
                               Text="Hazır"
                               Foreground="#3A5070"
                               FontFamily="Consolas" FontSize="10"
                               VerticalAlignment="Center"/>
                    <Button Content="KAPAT"
                            Width="100" Height="32"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderBrush="#2200FFE5" BorderThickness="1"
                            Foreground="#00FFE5"
                            FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                            Cursor="Hand"
                            Click="Kapat_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>